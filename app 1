// ==========================================
// 2. 白天收集：儲存筆記到暫存區
// ==========================================
function saveNote(content) {
  if (!content || content.trim() === '') {
    return { success: false, message: '內容不能為空喔！' };
  }
  var props = PropertiesService.getScriptProperties();
  var supabaseUrl = props.getProperty('SUPABASE_URL');
  var supabaseKey = props.getProperty('SUPABASE_KEY');
  var url = supabaseUrl + '/rest/v1/daily_notes';

  var options = {
    "method": "post",
    "headers": {
      "apikey": supabaseKey,
      "Authorization": "Bearer " + supabaseKey,
      "Content-Type": "application/json",
      "Prefer": "return=minimal"
    },
    "payload": JSON.stringify({ "content": content }),
    "muteHttpExceptions": true
  };

  try {
    UrlFetchApp.fetch(url, options);
    return { success: true, message: '儲存成功' };
  } catch (error) {
    return { success: false, message: '系統錯誤: ' + error.toString() };
  }
}

// ==========================================
// 3. 夜間處理：向量化大腦 (包含自動提取 due_at 完美版)
// ==========================================
function processNightlySummary() {
  var props = PropertiesService.getScriptProperties();
  var supabaseUrl = props.getProperty('SUPABASE_URL');
  var supabaseKey = props.getProperty('SUPABASE_KEY');
  var geminiKey = props.getProperty('GEMINI_API_KEY');
  
  var headers = {
    "apikey": supabaseKey,
    "Authorization": "Bearer " + supabaseKey,
    "Content-Type": "application/json",
    "Prefer": "return=minimal"
  };

  // --- 步驟 1：抓取今天的筆記 ---
  var getUrl = supabaseUrl + '/rest/v1/daily_notes?status=eq.pending';
  var response = UrlFetchApp.fetch(getUrl, { "method": "get", "headers": headers });
  var notes = JSON.parse(response.getContentText());

  if (notes.length === 0) {
    Logger.log("💤 今天沒有新筆記。");
    return;
  }
  var allContent = notes.map(function(n) { return "- " + n.content; }).join("\n");

  // --- 步驟 2：呼叫 AI 進行知識萃取 ---
  var geminiUrl = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=" + geminiKey;
  var nowIso = new Date().toISOString();

// ✨ 強制產生台灣時間，確保 AI 的「今天」是正確的
  var nowTW = Utilities.formatDate(new Date(), "Asia/Taipei", "yyyy-MM-dd'T'HH:mm:ssXXX");

  var promptText = `你是知識萃取專家。請分析以下筆記，萃取出「知識節點」。
  【時間基準】現在的台灣標準時間是：${nowTW}。
  【重要格式規則】
  1. 請嚴格將結果以「純 JSON 陣列」格式回傳，開頭必須是 [ ，結尾必須是 ]。
  2. 請以知識點, 單字, 想法, 代辦事項進行歸類
  3. 如果 category 是「待辦事項」，請推算它的日期，並嚴格以純字串 YYYY-MM-DD 格式存入 due_at 欄位（例如："2026-04-15"）。絕對不要加上任何時間或時區代碼。
  4. 如果沒有明確時間，或 category 不是待辦事項，due_at 的值必須是 null (注意：不要加雙引號)。
  內容：
  ${allContent}`;

  var geminiOptions = {
    "method": "post",
    "contentType": "application/json",
    "payload": JSON.stringify({ "contents": [{"parts": [{"text": promptText}]}] }),
    "muteHttpExceptions": true
  };

  try {
    var aiResponse = fetchWithRetry(geminiUrl, geminiOptions);
    var aiJson = JSON.parse(aiResponse.getContentText());
    
    // 🛡️ 防護機制：檢查 Gemini 是否給了正常的答案
    if (!aiJson.candidates || !aiJson.candidates[0]) {
      Logger.log("❌ Gemini API 發生錯誤或拒絕回答！\n【詳細原因】: " + aiResponse.getContentText());
      return; // 終止程式，以免後續當機
    }
    
    var rawText = aiJson.candidates[0].content.parts[0].text;
    Logger.log("【AI 原始回傳】\n" + rawText);

    // 清洗並解析 JSON
    var cleanText = rawText.replace(/```json/gi, "").replace(/```/g, "").trim();
    var knowledgeNodes = JSON.parse(cleanText); 
    Logger.log("✅ 解析成功！共萃取出 " + knowledgeNodes.length + " 筆節點。");

   // --- 步驟 3：向量轉換與存檔 (包含 X 光機與防塞車引擎) ---
    var embedUrl = "https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=" + geminiKey;
    var insertUrl = supabaseUrl + '/rest/v1/knowledge_nodes'; 

    knowledgeNodes.forEach(function(node, index) {
      if (!node) return; 

      var vector = null;
      var highValueCategories = ["知識點", "單字", "想法"];

      // 1. 產生向量：判斷是否需要生成向量 (只有高價值才生成)
      if (highValueCategories.indexOf(node.category) !== -1) {
        var embedOptions = {
          "method": "post",
          "headers": { "Content-Type": "application/json" },
          "payload": JSON.stringify({
            "model": "models/gemini-embedding-001",
            "content": {"parts": [{"text": node.content}]},
            "outputDimensionality": 768
          }),
          "muteHttpExceptions": true
        };
        
        try {
          // 🛡️ 使用防塞車引擎呼叫 Gemini Embedding API
          var embedResponse = fetchWithRetry(embedUrl, embedOptions);
          var embedRes = JSON.parse(embedResponse.getContentText());
          if (embedRes.embedding) {
            vector = "[" + embedRes.embedding.values.join(",") + "]";
          }
        } catch (e) {
          Logger.log(`⚠️ 第 ${index+1} 筆節點向量生成失敗：${e.message}`);
        }
      }

      // 📦 把時間與算好的向量一起打包給 Supabase
      var supabasePayload = {
        "category": node.category,
        "content": node.content,
        "embedding": vector,          
        "due_at": node.due_at || null, 
        // ✨ 新增這行：強制寫入我們在上面算好的台灣日期 (nowTW)
        "created_at": nowTW 
      };

      var supabaseOptions = {
        "method": "post",
        "headers": headers, 
        "payload": JSON.stringify(supabasePayload),
        "muteHttpExceptions": true
      };

      try {
        // 3. ✨ 使用防塞車引擎發送到 Supabase
        var dbResponse = fetchWithRetry(insertUrl, supabaseOptions);
        var statusCode = dbResponse.getResponseCode();
        
        // 🔍 X 光機：詳細檢查 Supabase 的回應
        if (statusCode >= 200 && statusCode < 300) {
          Logger.log(`✅ [${index+1}/${knowledgeNodes.length}] 成功存入: ${node.category}`);
        } else {
          Logger.log(`❌ [${index+1}/${knowledgeNodes.length}] 存檔失敗！HTTP 狀態碼：${statusCode}`);
          Logger.log(`🔍 Supabase 報錯原因：${dbResponse.getContentText()}`);
          Logger.log(`📦 當時的包裹內容：${JSON.stringify(supabasePayload)}`);
        }
      } catch (e) {
        Logger.log(`❌ 網路傳輸崩潰：${e.toString()}`);
      }
    });

    // --- 步驟 4：把原本的 Line 訊息標記為 processed ---
    UrlFetchApp.fetch(supabaseUrl + '/rest/v1/daily_notes?status=eq.pending', {
      "method": "patch",
      "headers": headers, 
      "payload": JSON.stringify({ "status": "processed" })
    });
    
    Logger.log("✨ 任務大功告成！");

  } catch (err) {
    Logger.log("❌ 系統發生崩潰：" + err.toString());
  }
}

// ==========================================
// 4. 向量搜尋：混合檢索
// ==========================================
function searchKnowledge(userQuery) {
  var props = PropertiesService.getScriptProperties();
  var supabaseUrl = props.getProperty('SUPABASE_URL');
  var supabaseKey = props.getProperty('SUPABASE_KEY');
  var geminiKey = props.getProperty('GEMINI_API_KEY');

  var embedUrl = "https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=" + geminiKey;
  var embedOptions = {
  "method": "post",
  "headers": { "Content-Type": "application/json" },
  "payload": JSON.stringify({
    "model": "models/gemini-embedding-001",
    "content": {"parts": [{"text": node.content}]},
    "outputDimensionality": 768
  }),
  "muteHttpExceptions": true
};
var embedResponse = fetchWithRetry(embedUrl, embedOptions);
  
  var embedResult = JSON.parse(embedResponse.getContentText());
  if (!embedResult.embedding) return "❌ 向量服務暫時不可用。";
  var queryVector = embedResult.embedding.values;

  var rpcUrl = supabaseUrl + '/rest/v1/rpc/match_knowledge_nodes';
  var response = UrlFetchApp.fetch(rpcUrl, {
    "method": "post",
    "headers": {
      "apikey": supabaseKey,
      "Authorization": "Bearer " + supabaseKey,
      "Content-Type": "application/json"
    },
    "payload": JSON.stringify({
      "query_embedding": queryVector, 
      "query_text": userQuery,       
      "match_threshold": 0.4,         
      "match_count": 8                
    }),
    "muteHttpExceptions": true
  });
  
  if (response.getResponseCode() !== 200) return "❌ 連結大腦資料庫時發生技術錯誤。";

  var searchResult = JSON.parse(response.getContentText());
  if (searchResult.length === 0) return "❌ 在大腦裡找不到相關記憶。";

  var contextText = searchResult.map(r => {
    var dateStr = new Date(r.created_at).toLocaleDateString('zh-TW');
    return `[紀錄日期: ${dateStr}] [分類: ${r.category}]: ${r.content}`;
  }).join("\n\n");

  var geminiUrl = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=" + geminiKey;
  var promptText = `你是我的第二大腦助手。今天的日期是 ${new Date().toLocaleDateString('zh-TW')}。
請根據以下背景知識回答問題。

【背景知識記憶】：
${contextText}

【我的問題】：${userQuery}`;

  var aiResponse = UrlFetchApp.fetch(geminiUrl, {
    "method": "post",
    "headers": { "Content-Type": "application/json" },
    "payload": JSON.stringify({ "contents": [{"parts": [{"text": promptText}]}] })
  });
  
  return JSON.parse(aiResponse.getContentText()).candidates[0].content.parts[0].text;
}

// ==========================================
// 5. Line Bot 入口：處理傳入訊息
// ==========================================
function doPost(e) {
  var props = PropertiesService.getScriptProperties();
  var lineToken = props.getProperty('LINE_ACCESS_TOKEN');
  try {
    var contents = JSON.parse(e.postData.contents);
    var event = contents.events[0];
    if (!event) return;

    var replyToken = event.replyToken;
    var userMessage = event.message.text;

    if (userMessage.indexOf("問 ") === 0 || userMessage.indexOf("Q:") === 0) {
      var query = userMessage.replace("問 ", "").replace("Q:", "").trim();
      var responseText = "🔍 正在檢索大腦...\n---\n" + searchKnowledge(query);
      replyToLine(replyToken, responseText, lineToken);
    } else {
      saveNote(userMessage);
    }
  } catch (err) {
    Logger.log("發生錯誤：" + err.toString());
  }
}

function replyToLine(replyToken, text, token) {
  var url = 'https://api.line.me/v2/bot/message/reply';
  UrlFetchApp.fetch(url, {
    'headers': {
      'Content-Type': 'application/json; charset=UTF-8',
      'Authorization': 'Bearer ' + token,
    },
    'method': 'post',
    'payload': JSON.stringify({
      'replyToken': replyToken,
      'messages': [{ 'type': 'text', 'text': text }],
    }),
    'muteHttpExceptions': true
  });
}

function cleanupProcessedNotes() {
  var props = PropertiesService.getScriptProperties();
  var supabaseUrl = props.getProperty('SUPABASE_URL');
  var supabaseKey = props.getProperty('SUPABASE_KEY');
  
  var deleteUrl = supabaseUrl + '/rest/v1/daily_notes?status=eq.processed';
  var options = {
    "method": "delete",
    "headers": {
      "apikey": supabaseKey,
      "Authorization": "Bearer " + supabaseKey
    },
    "muteHttpExceptions": true
  };
  var response = UrlFetchApp.fetch(deleteUrl, options);
  Logger.log("清理結果：" + response.getResponseCode());
}

/**
 * 智慧重試引擎 (Exponential Backoff)
 * 專門對付 API 429 流量管制與 500 伺服器錯誤
 */
function fetchWithRetry(url, options, maxRetries = 3) {
  for (let i = 0; i < maxRetries; i++) {
    try {
      // 嘗試發送請求
      var response = UrlFetchApp.fetch(url, options);
      var statusCode = response.getResponseCode();

      // 如果遇到 429 (請求過多) 或 500 以上 (伺服器當機)
      if (statusCode === 429 || statusCode >= 500) {
        // 計算等待時間：1秒, 2秒, 4秒... 並加上一點隨機毫秒數 (Jitter) 防止多個請求同時硬擠
        var sleepTime = Math.pow(2, i) * 1000 + Math.random() * 1000; 
        Logger.log(`⚠️ API 塞車中 (狀態碼: ${statusCode})。等待 ${Math.round(sleepTime/1000)} 秒後進行第 ${i + 1} 次重試...`);
        
        Utilities.sleep(sleepTime);
        continue; // 重新執行下一圈迴圈
      }

      // 如果成功 (200) 或遇到其他我們應該直接面對的錯誤 (例如 400 參數錯誤)，直接回傳
      return response;

    } catch (e) {
      Logger.log(`⚠️ 網路層異常: ${e.message}。進行第 ${i + 1} 次重試...`);
      Utilities.sleep(2000);
    }
  }
  
  // 如果重試了 3 次還是不行，就果斷拋出錯誤讓系統停止，保護資料庫
  throw new Error("❌ 呼叫 API 失敗已達最大重試次數 (3次)。");
}
