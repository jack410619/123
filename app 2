// 核心設定：請在專案屬性中填入對應的 Key
const CONFIG = {
  SUPABASE_URL: PropertiesService.getScriptProperties().getProperty('SUPABASE_URL'),
  SUPABASE_KEY: PropertiesService.getScriptProperties().getProperty('SUPABASE_KEY'),
  GEMINI_KEY: PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY'),
  LINE_TOKEN: PropertiesService.getScriptProperties().getProperty('LINE_ACCESS_TOKEN'),
  CWA_API_KEY: PropertiesService.getScriptProperties().getProperty('CWA_API_KEY'),
  MY_LINE_USER_ID: PropertiesService.getScriptProperties().getProperty('MY_LINE_USER_ID') // 可選
};

/**
 * 終極時間轉換器：輸入台灣時間，輸出精準的 UTC 查詢邊界
 */
function getTaiwanDayBoundsUTC(targetDateObj) {
  const twDateStr = Utilities.formatDate(targetDateObj, "Asia/Taipei", "yyyy-MM-dd");
  const twStart = new Date(`${twDateStr}T00:00:00+08:00`);
  const twEnd = new Date(`${twDateStr}T23:59:59+08:00`);
  return {
    twDateStr: twDateStr,
    startUTC: twStart.toISOString(),
    endUTC: twEnd.toISOString()
  };
}

/**
 * 早報：徹底移除 UTC 邏輯，改為純日期比對
 */
function sendMorningBrief() {
  const weatherInfo = fetchCWAWeather("臺中市");

  // 1. 取得台灣今天的純日期字串
  const todayStr = Utilities.formatDate(new Date(), "Asia/Taipei", "yyyy-MM-dd");

  // 2. 組合網址：直接使用 eq (等於) 查詢日期字串
  const categoryEncoded = encodeURIComponent('待辦事項');
  const taskUrl = `${CONFIG.SUPABASE_URL}/rest/v1/knowledge_nodes?category=eq.${categoryEncoded}&due_at=eq.${todayStr}`;
  
  // 3. 抓取資料 (fetchSupabase 內部已處理 API Key)
  const tasks = JSON.parse(fetchSupabase(taskUrl));

  let taskContent = tasks.length === 0 ? "今天沒有任務，祝你有輕鬆的一天！" : JSON.stringify(tasks);

  const prompt = `今天是 ${todayStr}。天氣：${weatherInfo}。任務：${taskContent}。
  你是我(Jack)的私人小助理，請以「☀️ 早安報報」為題做簡短問候並列出重點。`;
  
  const content = callGemini(prompt);
  pushToLine(content);
}

/**
 * 晚報/夜間報表：知識點總結 (純日期極致清爽版)
 */
function sendEveningReport() {
  const now = new Date();
  
  // 1. 智慧跨日判斷：凌晨 0 點 ~ 6 點執行，就退回「昨天」
  if (now.getHours() < 6) {
    now.setDate(now.getDate() - 1);
  }
  
  // 取得台灣時間的目標日期字串 (YYYY-MM-DD)
  const targetDateStr = Utilities.formatDate(now, "Asia/Taipei", "yyyy-MM-dd");
  const categoryEncoded = encodeURIComponent('待辦事項');
  
  // 2. ✨ 終極修復：直接用 eq 比對 created_at 的日期字串！
  const url = `${CONFIG.SUPABASE_URL}/rest/v1/knowledge_nodes?created_at=eq.${targetDateStr}&category=neq.${categoryEncoded}`;
  
  Logger.log("晚報查詢網址: " + url);

  const response = fetchSupabase(url);
  const nodes = JSON.parse(response);

  // 3. 防呆機制
  if (nodes.length === 0) {
    pushToLine(`🌙 晚報時間：大腦資料庫顯示，${targetDateStr} 沒有新增任何單字或知識點喔！早點休息吧！`);
    return;
  }

  // 4. AI 整理單字與知識點
  const prompt = `你是我的助理。請幫我做 ${targetDateStr} 的 review of the day：${JSON.stringify(nodes)}。
  請以「🌙 晚間 Report」為題，整理出關鍵單字、簡要知識點(不用解釋)與寫的行程(若有)。`;
  
  const content = callGemini(prompt);
  pushToLine(content);
}

// --- 輔助函數 ---
function fetchSupabase(url) {
  const options = { "headers": { "apikey": CONFIG.SUPABASE_KEY, "Authorization": `Bearer ${CONFIG.SUPABASE_KEY}` } };
  return UrlFetchApp.fetch(url, options).getContentText();
}

/**
 * 終極版推播函數 (強制即時讀取屬性)
 */
function pushToLine(text) {
  const props = PropertiesService.getScriptProperties();
  const token = props.getProperty('LINE_ACCESS_TOKEN');
  const userId = props.getProperty('MY_LINE_USER_ID');

  if (!userId) {
    Logger.log("❌ 錯誤：找不到 Line User ID");
    return;
  }

  const url = 'https://api.line.me/v2/bot/message/push';
  const payload = {
    "to": userId.trim(), 
    "messages": [{ "type": "text", "text": text }]
  };
  
  const options = {
    "method": "post",
    "headers": { 
      "Content-Type": "application/json", 
      "Authorization": `Bearer ${token}` 
    },
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };
  
  UrlFetchApp.fetch(url, options);
}

/**
 * 抓取中央氣象署 (CWA) 36 小時天氣預報
 * 預設抓取「臺北市」，可自行更改
 */
function fetchCWAWeather(cityName = "臺中市") {
  const apiKey = PropertiesService.getScriptProperties().getProperty('CWA_API_KEY');
  // 注意：CWA 的城市名稱必須是繁體標準字，例如「臺北市」、「新北市」、「臺中市」
  const url = `https://opendata.cwa.gov.tw/api/v1/rest/datastore/F-C0032-001?Authorization=${apiKey}&locationName=${encodeURIComponent(cityName)}`;
  
  try {
    const response = UrlFetchApp.fetch(url, { "muteHttpExceptions": true });
    const data = JSON.parse(response.getContentText());
    
    // 檢查是否有回傳正確資料
    if (data.success !== "true") return "暫時無法取得氣象署資料";

    const elements = data.records.location[0].weatherElement;
    
    // 提取我們需要的數據：Wx(天氣)、PoP(降雨機率)、MinT(最低溫)、MaxT(最高溫)
    const wx = elements.find(e => e.elementName === 'Wx').time[0].parameter.parameterName;
    const pop = elements.find(e => e.elementName === 'PoP').time[0].parameter.parameterName;
    const minT = elements.find(e => e.elementName === 'MinT').time[0].parameter.parameterName;
    const maxT = elements.find(e => e.elementName === 'MaxT').time[0].parameter.parameterName;
    
    return `☁️ ${wx} | 🌡️ 氣溫：${minT}~${maxT}°C | ☔ 降雨機率：${pop}%`;
    
  } catch (err) {
    Logger.log("CWA API 錯誤: " + err.message);
    return "天氣資料讀取失敗";
  }
}
/**
 * 呼叫 Gemini API 的核心函數
 */
function callGemini(promptText) {
  // 從專案屬性中抓取 API Key (確保你新專案有設定 GEMINI_API_KEY)
  const apiKey = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  
  // 使用 Gemini 1.5 Flash (速度快、適合文字處理)
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;
  
  const payload = {
    "contents": [{
      "parts": [{
        "text": promptText
      }]
    }]
  };
  
  const options = {
    "method": "post",
    "contentType": "application/json",
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };
  
  try {
    const response = UrlFetchApp.fetch(url, options);
    const json = JSON.parse(response.getContentText());
    
    // 成功回傳生成的文字
    if (json.candidates && json.candidates.length > 0) {
      return json.candidates[0].content.parts[0].text;
    } else {
      Logger.log("Gemini 回傳異常：" + response.getContentText());
      return "【AI 總結失敗】請檢查 API 額度或回傳格式。";
    }
  } catch (err) {
    Logger.log("呼叫 Gemini 發生錯誤：" + err.toString());
    return "【系統異常】無法連線至 AI 引擎。";
  }
}

/**
 * App 2: 清理過期待辦事項 (防呆靜默 + 2天寬限期版)
 */
function cleanupExpiredTasks() {
  const props = PropertiesService.getScriptProperties();
  const supabaseUrl = props.getProperty('SUPABASE_URL');
  const supabaseKey = props.getProperty('SUPABASE_KEY');
  
  // 💡 核心修改：計算出「兩天前」的時間基準
  const thresholdDate = new Date();
  thresholdDate.setDate(thresholdDate.getDate() - 2); 
  const thresholdIso = thresholdDate.toISOString();
  
  // 告訴資料庫：只刪除 due_at 早於「兩天前」的待辦事項
  const deleteUrl = `${supabaseUrl}/rest/v1/knowledge_nodes?category=eq.待辦事項&due_at=lt.${thresholdIso}`;
  
  const options = {
    "method": "delete",
    "headers": { 
      "apikey": supabaseKey, 
      "Authorization": `Bearer ${supabaseKey}`,
      "Prefer": "return=representation" // 要求 Supabase 回傳被刪掉的資料
    },
    "muteHttpExceptions": true 
  };
  
  try {
    const response = UrlFetchApp.fetch(deleteUrl, options);
    const code = response.getResponseCode();
    
    if (code >= 200 && code < 300) {
      const deletedData = JSON.parse(response.getContentText() || "[]");
      
      if (deletedData.length === 0) {
        Logger.log("✨ 掃描完畢：目前沒有過期超過 2 天的待辦事項需要清理。");
      } else {
        Logger.log(`✅ 清理成功：共移除了 ${deletedData.length} 筆過期超過 2 天的任務！`);
      }
    } else {
      Logger.log(`⚠️ 清理發生異常，伺服器回應碼：${code}，原因：${response.getContentText()}`);
    }
  } catch (err) {
    Logger.log(`❌ 系統執行崩潰：${err.toString()}`);
  }
}
