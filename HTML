<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AI Second Brain</title>
  <style>
    :root {
      --primary: #6366f1;
      --secondary: #a855f7;
      --bg: #0f172a;
      --card-bg: rgba(255, 255, 255, 0.05);
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
      color: #e2e8f0;
      min-height: 100vh;
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px;
    }

    .container {
      width: 100%;
      max-width: 480px;
      animation: fadeIn 0.8s ease-out;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    h1 {
      font-size: 24px;
      font-weight: 800;
      text-align: center;
      background: linear-gradient(to right, #818cf8, #c084fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 30px;
      letter-spacing: -1px;
    }

    .glass-card {
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .label { font-size: 12px; font-weight: 600; text-transform: uppercase; color: #94a3b8; margin-bottom: 8px; display: block; }

    textarea, input {
      width: 100%;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 12px;
      color: white;
      font-size: 16px;
      transition: 0.3s;
      box-sizing: border-box;
      margin-bottom: 15px;
    }

    textarea:focus, input:focus { outline: none; border-color: var(--primary); background: rgba(0, 0, 0, 0.4); }

    button {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      font-size: 16px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
    }

    .btn-save { background: linear-gradient(to right, #4f46e5, #7c3aed); color: white; }
    .btn-search { background: rgba(255, 255, 255, 0.1); color: white; border: 1px solid rgba(255, 255, 255, 0.2); }
    
    button:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4); }
    button:active { transform: translateY(0); }
    button:disabled { opacity: 0.5; cursor: not-allowed; }

    /* 脈動動畫 */
    .pulse { animation: pulse-animation 2s infinite; }
    @keyframes pulse-animation {
      0% { box-shadow: 0 0 0 0px rgba(99, 102, 241, 0.4); }
      100% { box-shadow: 0 0 0 20px rgba(99, 102, 241, 0); }
    }

    #result {
      margin-top: 20px;
      padding: 18px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 16px;
      font-size: 15px;
      line-height: 1.6;
      border-left: 4px solid var(--primary);
      display: none;
      animation: slideIn 0.4s ease-out;
    }

    @keyframes slideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }

    .status-msg { text-align: center; font-size: 13px; margin-top: 10px; color: #818cf8; min-height: 20px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>BRAIN CORE v2.0</h1>

    <div class="glass-card">
      <span class="label">Input Thought</span>
        <button onclick="getAndClearCache()" style="background-color: #856404; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; transition: opacity 0.2s;">
          複製並清除
        </button>
      </div> <div id="cache-text" ></div>
    </div>

    <div class="glass-card">
      <span class="label">Input Thought</span>
      <textarea id="noteInput" rows="4" placeholder="在此輸入新知識、見解或待辦事項..."></textarea>
      <button id="saveBtn" class="btn-save" onclick="saveNote()">
        <span>✦</span> 儲存記憶
      </button>
      <div id="saveStatus" class="status-msg"></div>
    </div>

    <div class="glass-card">
      <span class="label">Semantic Search</span>
      <input id="queryInput" placeholder="詢問你的大腦...">
      <button id="searchBtn" class="btn-search" onclick="searchBrain()">
        <span>🔍</span> 檢索內容
      </button>
      <div id="result"></div>
    </div>
    
  </div> <script>
  // ⚠️ 必填：你必須在這裡補上你的 Supabase 網址與金鑰，網頁才知道去哪抓資料！
  const SUPABASE_URL = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp3Z3FmdWtkc3l0cmlvdnZhd3F0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MjAxOTAsImV4cCI6MjA5MTM5NjE5MH0.s6ZZFC7YmlyOvtYtVHhBKKrLJ3tfl_QRneEqClSCQ9U"; 
  const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp3Z3FmdWtkc3l0cmlvdnZhd3F0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MjAxOTAsImV4cCI6MjA5MTM5NjE5MH0.s6ZZFC7YmlyOvtYtVHhBKKrLJ3tfl_QRneEqClSCQ9U";

  // 1. 初始化時檢查快取
  window.onload = function() {
    fetchClipboard(); 
    
    // 防呆：確保你有定義 fetchNotes 才執行，避免當機
    if (typeof fetchNotes === "function") {
      fetchNotes();     
    }
  };

  // 2. 雲端剪貼簿：抓取資料
  async function fetchClipboard() {
    if (SUPABASE_URL === "https://jwgqfukdsytriovvawqt.supabase.co") {
      console.error("❌ 尚未設定 SUPABASE_URL");
      return;
    }

    const url = `${SUPABASE_URL}/rest/v1/daily_notes?status=eq.cached&select=content`;
    try {
      const response = await fetch(url, {
        headers: { "apikey": SUPABASE_KEY, "Authorization": `Bearer ${SUPABASE_KEY}` }
      });
      const data = await response.json();
      
      const container = document.getElementById('clipboard-container');
      const textElem = document.getElementById('cache-text');
      
      if (data && data.length > 0) {
        container.style.display = 'block';
        textElem.innerText = data[0].content;
      } else {
        container.style.display = 'none';
      }
    } catch (e) {
      console.error("抓取快取失敗：", e);
    }
  }

  // 3. 雲端剪貼簿：取走並刪除
  async function getAndClearCache() {
    const text = document.getElementById('cache-text').innerText;
    navigator.clipboard.writeText(text); // 複製到電腦剪貼簿
    
    const url = `${SUPABASE_URL}/rest/v1/daily_notes?status=eq.cached`;
    await fetch(url, {
      method: "DELETE",
      headers: { "apikey": SUPABASE_KEY, "Authorization": `Bearer ${SUPABASE_KEY}` }
    });
    
    alert("📋 內容已複製，並從雲端清除！");
    fetchClipboard(); // 重新整理 UI
  }

  // 👇 注意：請務必把原本被你刪掉的 saveNote() 和 searchBrain() 等函數補在這裡！
  
</script>
</body>
</html>
